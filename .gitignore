.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ── Virtualenvs ──────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env
.env.local

# ── PyInstaller build output ─────────────────────────────────────────────────
build/
dist/

